.hero-actions {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-actions .btn {
  min-width: 220rpx;
}

.single-input {
  margin-top: 14rpx;
  width: 100%;
  min-height: 86rpx;
  border-radius: 18rpx;
  border: 2rpx solid #c5d9f2;
  background: #ffffff;
  color: #17385f;
  font-size: 30rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.name-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.assessment-overlay {
  position: fixed;
  inset: 0;
  background: rgba(8, 17, 33, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  z-index: 99;
}

.assessment-panel {
  width: 100%;
  max-height: 90vh;
  overflow: auto;
  border-radius: 24rpx;
  border: 2rpx solid #bfd4f0;
  background: linear-gradient(155deg, #eff6ff, #e4efff);
  padding: 20rpx;
  box-sizing: border-box;
}

.zone-map {
  margin-top: 12rpx;
  position: relative;
  height: 520rpx;
  border-radius: 20rpx;
  border: 2rpx solid #bfd4f0;
  background: radial-gradient(circle at 52% 16%, rgba(142, 179, 236, 0.28), rgba(230, 240, 255, 0.86));
}

.zone-dot {
  position: absolute;
  transform: translate(-50%, -50%);
  border-radius: 999rpx;
  border: 2rpx solid #9dbbe4;
  background: #dcecff;
  color: #1b406f;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  line-height: 1.3;
}

.zone-dot::after {
  border: none;
}
