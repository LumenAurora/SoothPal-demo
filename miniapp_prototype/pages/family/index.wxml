<view class="page-shell">
  <view class="card">
    <text class="kicker">家属关怀视图</text>
    <view class="title">亲情号摘要通知</view>
    <view class="subtitle">仅展示趋势与风险，不展示详细隐私内容。</view>
  </view>

  <view class="card">
    <view class="section-title">家属端实时摘要</view>
    <view class="family-message">{{familyMessage}}</view>
  </view>

  <view class="card">
    <view class="row">
      <text class="section-title">今日痛感</text>
      <text class="family-value">{{latestPain}}</text>
    </view>
    <text class="muted">用于提醒家属关注变化趋势，不展示详细病历描述。</text>
  </view>

  <view class="card" wx:if="{{latestAlert}}">
    <view class="row">
      <text class="section-title">最近预警</text>
      <text class="tag">{{latestAlert.levelLabel}}</text>
    </view>
    <text class="muted">触发原因：{{latestAlert.reason}}</text>
    <text class="muted">时间：{{latestAlert.time}}</text>
  </view>

  <view class="card" wx:if="{{noRecordDays >= 3}}">
    <view class="section-title">失访提醒</view>
    <text class="muted">已超过 {{noRecordDays}} 天未记录，请提醒家人尽快完成随访。</text>
  </view>
</view>
