.chart-row {
  margin-top: 14rpx;
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  overflow-x: auto;
  padding-bottom: 10rpx;
}

.bar-group {
  min-width: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.bar {
  width: 40rpx;
  border-radius: 14rpx 14rpx 6rpx 6rpx;
}

.bar.pain {
  background: linear-gradient(180deg, #ef6674, #f18f53);
}

.bar.steps {
  background: linear-gradient(180deg, #3cb5a5, #3d7ddf);
}

.bar-value {
  font-size: 24rpx;
  color: #1e406e;
  font-weight: 600;
}

.bar-label {
  font-size: 23rpx;
  color: #5c7492;
}

.bullet-item {
  margin-top: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.bullet-dot {
  color: #2f71d8;
  margin-top: 3rpx;
  font-weight: 700;
}

.bullet-text {
  flex: 1;
}
