<view class="page-shell">
  <view class="hero-card">
    <text class="kicker">社群</text>
    <view class="title">一起交流，互相支持</view>
    <view class="subtitle">提问、经验、打卡心得</view>
    <view class="post-row">
      <input
        class="post-input"
        value="{{postInput}}"
        bindinput="onPostInput"
        placeholder="说说你今天的情况"
        placeholder-style="color:#7f93b0;"
      />
      <button class="btn btn-primary" bindtap="onPost">发布</button>
    </view>
  </view>

  <block wx:for="{{threads}}" wx:key="id">
    <view class="card thread-card">
      <view class="thread-avatar">{{item.room[0]}}</view>
      <view class="thread-main">
        <view class="thread-room">{{item.room}}</view>
        <view class="thread-title">{{item.title}}</view>
        <text class="muted">{{item.meta}}</text>
      </view>
    </view>
  </block>
</view>
