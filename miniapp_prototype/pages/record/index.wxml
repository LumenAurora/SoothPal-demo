<view class="page-shell">
  <view class="card">
    <view class="row">
      <view class="section-title">身体疼痛区域采集</view>
      <view class="side-switch">
        <button class="btn btn-small {{side === 'front' ? 'btn-primary' : ''}}" data-side="front" bindtap="onSwitchSide">前视</button>
        <button class="btn btn-small {{side === 'back' ? 'btn-primary' : ''}}" data-side="back" bindtap="onSwitchSide">后视</button>
      </view>
    </view>

    <view class="capture-steps">
      <text class="tag">1. 先选大致区域</text>
      <text class="tag">2. 再点细分部位</text>
      <text class="tag">3. 保存并评估</text>
    </view>

    <view class="body-map">
      <view class="silhouette">
        <view class="part head"></view>
        <view class="part neck"></view>
        <view class="part torso"></view>
        <view class="part arm left"></view>
        <view class="part arm right"></view>
        <view class="part hip"></view>
        <view class="part leg left"></view>
        <view class="part leg right"></view>
      </view>

      <block wx:for="{{visibleRegions}}" wx:key="id">
        <view
          class="zone {{item.selected ? 'zone-active' : ''}} {{item.active ? 'zone-focus' : ''}}"
          style="left:{{item.x}}%; top:{{item.y}}%; width:{{item.w}}%; height:{{item.h}}%;"
          data-id="{{item.id}}"
          bindtap="onTapRegion"
        >
          <text>{{item.shortLabel}}</text>
          <text wx:if="{{item.fineCount > 0}}" class="zone-count">{{item.fineCount}}</text>
        </view>
      </block>

      <view class="map-hint">先点大区域，再点小部位，可重复补充。</view>
    </view>

    <view class="card quality-card quality-{{quality.level}}">
      <view class="row">
        <text class="section-title">采集质量：{{quality.label}}</text>
        <text class="score">{{quality.score}}</text>
      </view>
      <text class="muted">{{quality.hint}}</text>
    </view>

    <view class="card">
      <view class="section-title">今天疼痛强度：{{intensity}} / 10</view>
      <slider
        min="0"
        max="10"
        step="1"
        value="{{intensity}}"
        block-size="28"
        activeColor="#ff8a7a"
        bindchange="onIntensityChange"
      ></slider>
    </view>

    <view class="card">
      <view class="section-title">已选区域</view>
      <view wx:if="{{selectedLabels.length}}" class="tag-wrap">
        <block wx:for="{{selectedLabels}}" wx:key="*this">
          <text class="tag">{{item}}</text>
        </block>
      </view>
      <text wx:else class="muted">请选择至少一个疼痛区域。</text>
    </view>

    <view class="card" wx:if="{{activeRegion}}">
      <view class="row">
        <view class="section-title">{{activeRegion.label}} · 精细定位</view>
        <button class="btn btn-small" data-id="{{activeRegion.id}}" bindtap="onRemoveRegion">移除此区</button>
      </view>
      <view class="tag-wrap">
        <block wx:for="{{activeFineOptions}}" wx:key="label">
          <button
            class="btn btn-small {{item.selected ? 'btn-primary' : ''}}"
            data-region="{{activeRegion.id}}"
            data-label="{{item.label}}"
            bindtap="onTapFine"
          >
            {{item.label}}
          </button>
        </block>
      </view>
    </view>

    <view class="card" wx:else>
      <text class="muted">点选任意大区域后，可继续选择细分部位。</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">语音一句话转结构化</view>
    <textarea class="voice-input" value="{{transcript}}" bindinput="onTranscriptInput" maxlength="-1" placeholder="例如：今天右膝更疼，晚上明显，影响走路。" placeholder-style="color:#7b8fae;"></textarea>
    <view class="voice-actions">
      <button class="btn" bindtap="onParseTranscript">结构化解析</button>
      <button class="btn" bindtap="goDashboard">查看趋势</button>
      <button class="btn btn-primary" bindtap="onSaveRecord">保存并评估</button>
    </view>
    <text class="muted">最近一次保存：{{lastSavedAt}}</text>
  </view>

  <view class="card">
    <view class="section-title">结构化结果预览</view>
    <block wx:for="{{extraction}}" wx:key="key">
      <view class="extract-row">
        <text>{{item.label}}</text>
        <text class="extract-value">{{item.value}}</text>
      </view>
    </block>
  </view>
</view>
