<view class="page-shell">
  <view class="card">
    <text class="kicker">AI 辅助问答</text>
    <view class="title">个体化问答（带引用）</view>
    <view class="subtitle">先脱敏再检索，命中高危词时优先提示尽快就医。</view>
  </view>

  <view class="card">
    <view class="section-title">请输入问题</view>
    <textarea class="ask-input" value="{{query}}" bindinput="onInput" maxlength="-1" placeholder="例如：我最近晚上膝盖痛得睡不着，先做什么比较好？" placeholder-style="color:#7b8fae;"></textarea>
    <view class="ask-actions">
      <button class="btn btn-primary" bindtap="onSubmit">提交问题</button>
      <button class="btn" bindtap="onUseDemoQuestion">载入演示提问</button>
    </view>
  </view>

  <view class="card" wx:if="{{result}}">
    <view class="section-title">脱敏与检索流程</view>
    <view class="query-box">
      <text class="query-label">脱敏前 Query</text>
      <text class="query-text">{{result.rawQuery}}</text>
    </view>
    <view class="query-box query-box-safe">
      <text class="query-label">脱敏后 Query</text>
      <text class="query-text">{{result.redactedQuery}}</text>
    </view>
  </view>

  <view class="card {{result && result.isHighRisk ? 'alert-high' : ''}}" wx:if="{{result}}">
    <view class="section-title">AI 回答</view>
    <view class="answer-text">{{result.answer}}</view>
    <view class="tag-wrap" wx:if="{{result.citations.length}}">
      <block wx:for="{{result.citations}}" wx:key="*this">
        <text class="tag">{{item}}</text>
      </block>
    </view>
  </view>

  <view class="card" wx:if="{{result && result.chunks.length}}">
    <view class="section-title">命中知识片段</view>
    <block wx:for="{{result.chunks}}" wx:key="id">
      <view class="chunk-item">
        <text class="chunk-title">{{item.title}}</text>
        <text class="chunk-id">{{item.id}}</text>
      </view>
    </block>
  </view>
</view>
