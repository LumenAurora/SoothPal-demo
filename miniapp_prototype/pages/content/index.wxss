.hero-actions {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-actions .btn {
  min-width: 220rpx;
}

.scenario-list {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.scenario-btn {
  min-width: 220rpx;
}

.bullet-row {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
  align-items: flex-start;
}

.bullet-dot {
  color: #2f6dd6;
  font-weight: 700;
  margin-top: 3rpx;
}

.feed-card {
  display: grid;
  gap: 8rpx;
}

.feed-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #173a68;
  line-height: 1.45;
}
