.post-row {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.post-input {
  width: 100%;
  min-height: 84rpx;
  border-radius: 18rpx;
  border: 2rpx solid #c5d9f2;
  background: #ffffff;
  color: #17385f;
  font-size: 29rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.thread-card {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.thread-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 999rpx;
  background: linear-gradient(125deg, #2e77df, #2fa8d4);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.thread-main {
  flex: 1;
  display: grid;
  gap: 6rpx;
}

.thread-room {
  color: #2a4c7b;
  font-size: 24rpx;
  font-weight: 600;
}

.thread-title {
  color: #153764;
  font-size: 31rpx;
  line-height: 1.5;
  font-weight: 700;
}
