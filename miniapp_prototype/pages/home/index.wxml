<view class="page-shell">
  <view class="hero-card">
    <view class="title">请告诉我，您正在经历何种疼痛困扰？</view>
    <input
      class="single-input"
      value="{{painInput}}"
      bindinput="onPainInput"
      placeholder="例如：右侧腰背突然刺痛，走路更疼"
      placeholder-style="color:#7f93b0;"
    />
    <view class="hero-actions">
      <button class="btn btn-primary" bindtap="onSubmitPain">继续</button>
      <button class="btn" wx:if="{{profileName}}" bindtap="onEnterApp">直接进入应用</button>
    </view>
  </view>

  <view class="card" wx:if="{{canAskName}}">
    <view class="section-title">好的，我了解了您的情况。请问怎么称呼您？</view>
    <view class="name-row">
      <input
        class="single-input"
        value="{{nameInput}}"
        bindinput="onNameInput"
        placeholder="请输入称呼"
        placeholder-style="color:#7f93b0;"
      />
      <button class="btn btn-primary" bindtap="onCreateProfile">创建档案</button>
    </view>
  </view>

  <view class="assessment-overlay" wx:if="{{showAssessment}}">
    <view class="assessment-panel">
      <view class="section-title">检测到疼痛发作，开始 2D 评估</view>
      <view class="side-switch">
        <button class="btn btn-small {{side === 'front' ? 'btn-primary' : ''}}" data-side="front" bindtap="onSwitchSide">前视</button>
        <button class="btn btn-small {{side === 'back' ? 'btn-primary' : ''}}" data-side="back" bindtap="onSwitchSide">后视</button>
      </view>

      <view class="zone-map">
        <block wx:for="{{visibleRegions}}" wx:key="id">
          <button
            class="zone-dot"
            data-id="{{item.id}}"
            bindtap="onTapRegion"
            style="left:{{item.x}}%; top:{{item.y}}%;"
          >
            {{item.shortLabel}}
          </button>
        </block>
      </view>

      <view class="section-title">疼痛强度 {{intensity}} / 10</view>
      <slider
        min="0"
        max="10"
        step="1"
        value="{{intensity}}"
        block-size="26"
        activeColor="#ff8a7a"
        bindchange="onIntensityChange"
      ></slider>

      <view class="tag-wrap" wx:if="{{selectedLabels.length}}">
        <block wx:for="{{selectedLabels}}" wx:key="*this">
          <text class="tag">{{item}}</text>
        </block>
      </view>

      <button class="btn btn-primary" bindtap="onFinishAssessment">完成采集</button>
    </view>
  </view>
</view>
